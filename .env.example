# Copiá este archivo como .env y completá tu API key de Kapso.
# El .env NO se sube al repo (está en .gitignore).

# KAPSO_API_BASE_URL es solo el host (sin /platform/v1): así lo esperan los
# scripts oficiales de Kapso (automate/integrate/observe-whatsapp).
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
